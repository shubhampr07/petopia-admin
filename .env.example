# Base URL of the Petopia API server (petopia-server). No trailing slash.
# The admin panel talks ONLY to this API — it never touches the database directly.
ADMIN_API_URL="http://localhost:4000"

# NOTE: Admin credentials (ADMIN_EMAIL / ADMIN_PASSWORD) live in the SERVER's
# .env (petopia-server), not here. The admin panel posts the login form to
# /api/admin/login, and the server validates against those credentials.
